# Email Service (Resend)
RESEND_API_KEY=re_123456789
EMAIL_FROM="DevGuardian <team@devguardian.site>"
CONTACT_TO="team@devguardian.site"

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAA...

# Security & Rate Limiting
# Rate Limit: 5 requests per hour (3600000 ms) per IP
RATE_LIMIT_MAX=5
RATE_LIMIT_WINDOW_MS=3600000
# Upstash Redis (optional; preferred for shared rate limit state)
UPSTASH_REDIS_REST_URL=https://your-upstash-rest-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token
RATE_LIMIT_REDIS_PREFIX=rate_limit
# Path to store rate limit data (ensure this is writable)
# For serverless environments (Netlify), prefer /tmp
RATE_FILE_PATH=/tmp/contact-rate-limit.json
LOG_PATH=/tmp/contact-security.log
